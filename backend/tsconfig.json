{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "shared": ["../shared/src/types/index.ts"]
    }
  },
  "include": ["src", "../shared/src"],
  "exclude": ["node_modules"]
}
