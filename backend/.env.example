PORT=3001
NODE_ENV=development

# ─── Database PostgreSQL ──────────────────────────────────────────────────────
# In produzione Render inietta DATABASE_URL automaticamente.
# In locale: docker run -e POSTGRES_PASSWORD=mtg -e POSTGRES_DB=mtgdb -p 5432:5432 postgres
# oppure usa Neon.tech / Supabase (tier gratuito).
DATABASE_URL=postgresql://postgres:mtg@localhost:5432/mtgdb

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Se GROQ_API_KEY è impostata, il backend usa Groq (cloud, gratuito, più veloce).
# Altrimenti usa Ollama in locale.
# Registrati su https://console.groq.com per ottenere una chiave gratuita.
GROQ_API_KEY=

# Ollama (AI locale — usato solo se GROQ_API_KEY è vuota)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
