{
  "name": "mtg-deck-creator",
  "version": "0.1.0",
  "private": true,
  "description": "MTG Commander deck builder — monorepo",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspace=frontend",
    "start": "NODE_ENV=production node -e \"require('tsx/cjs'); require('./backend/src/index.ts')\"",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "tsx": "^4.15.1"
  }
}
